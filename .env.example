# Server
PORT=5002
NODE_ENV=development

# Prefer DATABASE_URL in production (Railway)
# DATABASE_URL=postgresql://user:password@host:port/database

# Local PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=delima_psb
DB_USER=postgres
DB_PASSWORD=change_me

# JWT Secret
JWT_SECRET=change_me_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# Cloudinary (rotate these in Cloudinary dashboard if ever leaked)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional: require verified TLS cert for DATABASE_URL
# DB_SSL_REJECT_UNAUTHORIZED=true
